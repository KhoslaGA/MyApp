# Webhub4U — environment variables
# Copy to .env.local for dev, or set these in the Vercel project settings.
# Everything is optional: unset vars degrade gracefully (analytics stays
# dormant, leads log to the server console instead of being delivered).

# --- Analytics (Sprint 0) -------------------------------------------------
# GA4 Measurement ID. Analytics stays dormant until this is set.
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel ID — powers 2027 ad conversions + retargeting.
NEXT_PUBLIC_META_PIXEL_ID=

# --- Lead delivery (Sprint 1) ---------------------------------------------
# GoHighLevel inbound-webhook URL. If set, /api/demo-request forwards leads
# here (GHL-shaped payload) — takes priority over email.
GHL_WEBHOOK_URL=
# Resend email delivery (fallback if GHL is not set). Used by both
# /api/sendEmail and /api/demo-request.
RESEND_API_KEY=
EMAIL_FROM="Webhub4U <onboarding@resend.dev>"
EMAIL_TO=webhub4u@gmail.com
